PORT=5000

# Local MongoDB
# MONGODB_URI=mongodb://localhost:27017/placement-prep

# MongoDB Atlas (recommended)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/placement-prep?retryWrites=true&w=majority&appName=Cluster0

JWT_SECRET=your_super_secret_jwt_key_here_change_in_production_min_32_chars
JWT_EXPIRES_IN=7d
NODE_ENV=development
